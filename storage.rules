rules_version = '2';

// chapter-cc187 공용 Storage 규칙
// - Chapter 앱 유저: 본인 testUser/{uid}/… 사진 읽기·업로드·삭제·목록
// - Admin: tangbaboda@gmail.com 전체 접근
//
// ⚠️ delete 시 request.resource == null 이므로 create/update 와 분리해야 합니다.
// ⚠️ listAll() 은 match …/{date} 에 allow list 가 필요합니다.

service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.matches('(?i)^tangbaboda@gmail\\.com$');
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function canAccessUserPhotos(userId) {
      return isOwner(userId) || isAdmin();
    }

    function isValidImageUpload() {
      return request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // MVP: testUser/{userId}/{yyyy-MM-dd}/{fileName}
    match /testUser/{userId}/{date}/{fileName} {
      allow read: if canAccessUserPhotos(userId);
      allow create, update: if canAccessUserPhotos(userId) && isValidImageUpload();
      allow delete: if canAccessUserPhotos(userId);
    }

    match /testUser/{userId}/{date} {
      allow list: if canAccessUserPhotos(userId);
    }

    // (추후) users/{userId}/{yyyy-MM-dd}/{fileName}
    match /users/{userId}/{date}/{fileName} {
      allow read: if canAccessUserPhotos(userId);
      allow create, update: if canAccessUserPhotos(userId) && isValidImageUpload();
      allow delete: if canAccessUserPhotos(userId);
    }

    match /users/{userId}/{date} {
      allow list: if canAccessUserPhotos(userId);
    }

    // 실물 책 PDF (Admin Functions 업로드)
    match /pdfs/{fileName} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
